# Copy to `.env` and fill in. Loaded by `docker compose` automatically.

# Image tags
TAG=latest
LEGACY_TAG=2026-04-pre-cutover

# S3 artifact location (consumed by tfbp-data-init on every `up`)
ARTIFACT_BUCKET=brentlab-tfbp-artifacts
ARTIFACT_KEY=tfbp/2026-05-13/tfbp.duckdb
ARTIFACT_SHA256=

# AWS creds for the init container (read-only access to the artifact bucket
# is sufficient — scope the IAM user accordingly).
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Legacy Shiny only — Hugging Face token for runtime data fetch.
HF_TOKEN=

# --- Optional tuning knobs (defaults applied if unset) ---
# §6.3 DuckDB pool. Lower DUCKDB_MEMORY_LIMIT and TFBP_MEM_LIMIT during the
# legacy co-tenancy overlap so tfbp + shinyapp fit a 2GB host (see
# deploy/README.md "Legacy grace-period co-tenancy"). Retune from the cutover
# load test, not formulas.
#DUCKDB_MEMORY_LIMIT=800MB
#DUCKDB_MAX_TEMP_SIZE=2GB
#DB_MAX_OPEN_CONNS=2
#MAX_INFLIGHT_REQUESTS=128
#TFBP_MEM_LIMIT=1.6g
