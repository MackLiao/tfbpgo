# Reference symlink to the original Python project
/reference

# Runtime artifact (built by data_prep, never committed)
/tfbp.duckdb
/tfbp.duckdb.wal

# Deploy: per-publish manifest JSONs are CI artifacts, not source
/deploy/artifact-manifest.*.json

# Python
__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# Secrets
.env
.env.local

# OS
.DS_Store

# Go
backend/tfbp-server
backend/static/dist
*.test
coverage.out
*.out

# Frontend
frontend/node_modules/
frontend/dist/
backend/static/dist/

# k6 scenario summary outputs (operator-run artifacts, not source)
tests/loadtest/k6/scenarios/*.summary.json
tests/loadtest/k6/scenarios/*-summary.json

# chaos sampler CSV output (operator-run artifacts, written to /tmp or beside the script)
tests/loadtest/k6/chaos/sampler.csv
tests/loadtest/k6/chaos/*.csv

# Terraform (infra/ demo stack)
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform.lock.hcl
crash.log
